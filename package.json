{
  "name": "open-web-video-player",
  "version": "0.1.0",
  "description": "A video player supporting HLS, HTTP-FLV, WebRTC with H.264/H.265 codec",
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.0",
    "@ffmpeg/util": "^0.12.0",
    "eventemitter3": "^5.0.0",
    "flv.js": "^1.6.0",
    "hls.js": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "video",
    "player",
    "hls",
    "flv",
    "webrtc",
    "ffmpeg",
    "wasm"
  ],
  "author": "",
  "license": "MIT"
}
